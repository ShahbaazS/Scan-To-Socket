 <resources/>
 <connections>
  <connection>
   <sender>PopScanner</sender>
   <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
   <receiver>armMarkupsWidget</receiver>
   <slot>setMRMLScene(vtkMRMLScene*)</slot>
   <hints>
