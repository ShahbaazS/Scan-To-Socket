<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>PopScanner</class>
 <widget class="qMRMLWidget" name="PopScanner">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>450</width>
    <height>420</height>
   </rect>
  </property>
  <property name="sizePolicy">
   <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
    <horstretch>0</horstretch>
    <verstretch>0</verstretch>
   </sizepolicy>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="ctkCollapsibleButton" name="inputsCollapsibleButton">
     <property name="text">
      <string>Inputs</string>
     </property>
     <layout class="QFormLayout" name="formLayout_2">
      <item row="0" column="0">
       <widget class="QLabel" name="label">
        <property name="text">
         <string>Input file of patient scan (STL/OBJ):</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QLineEdit" name="inputFilePathEdit">
          <property name="toolTip">
           <string>Path to the input STL or OBJ file.</string>
          </property>
          <property name="placeholderText">
           <string>Select a file...</string>
          </property>
          <property name="SlicerParameterName" stdset="0">
           <string>inputFilePath</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="inputFileBrowseButton">
          <property name="text">
           <string>Browse...</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="ctkCollapsibleButton" name="markupsCollapsibleButton">
     <property name="text">
      <string>Landmark Registration</string>
     </property>
     <layout class="QFormLayout" name="formLayout_markups">
      <item row="2" column="0">
       <widget class="QLabel" name="label_armPoints">
        <property name="text">
         <string>Arm Landmarks (3 points):</string>
        </property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="qSlicerSimpleMarkupsWidget" name="armMarkupsWidget">
        <property name="toolTip">
         <string>Place 3 points on the arm scan.</string>
        </property>
        <property name="nodeTypes" stdset="0">
         <stringlist>
          <string>vtkMRMLMarkupsFiducialNode</string>
         </stringlist>
        </property>
       </widget>
      </item>
      <item row="1" column="0" colspan="2">
       <widget class="QTextEdit" name="LandmarkRegInstructions">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="html">
         <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'.AppleSystemUIFont'; font-size:9pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;How to apply landmark registration:&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;1. Go to Arm Landmarks (3 points) and click "Create new Point List"&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;1a. Place point 1 on the top of the shoulder&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;1b. Place point 2 at the bottom of the stub, in the centre&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;1c. Place point 3 at the side of the widest part of the upper arm&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;2. Enter the Wall Thickness of the shoulder prosthetic&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;3. Input the "shoulder to elbow" distance in the box&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;4. Click "Initialize Preview" to see the prosthetic and to make changes&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;5. If everything is ready, click "Generate Prosthetic Socket"&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QWidget" name="wallThicknessWidget">
     <layout class="QFormLayout" name="formLayout_wallThickness">
      <item row="0" column="0">
       <widget class="QLabel" name="wallThicknessLabel">
        <property name="text">
         <string>Wall Thickness:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="ctkSliderWidget" name="wallThicknessSlider">
        <property name="toolTip">
         <string>Socket shell thickness in mm. 3–5 mm is typical for FDM-printed sockets. Inner clearance of 1.5 mm is added automatically for fit.</string>
        </property>
        <property name="minimum">
         <double>2</double>
        </property>
        <property name="maximum">
         <double>12</double>
        </property>
        <property name="value">
         <double>4</double>
        </property>
        <property name="singleStep">
         <double>0.5</double>
        </property>
        <property name="suffix">
         <string> mm</string>
        </property>
        <property name="decimals">
         <double>1</double>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QPushButton" name="applyButton">
     <property name="enabled">
      <bool>false</bool>
     </property>
     <property name="toolTip">
      <string>Generate the final prosthetic socket model.</string>
     </property>
     <property name="text">
      <string>Generate Prosthetic Socket</string>
     </property>
    </widget>
   </item>

   <item>
    <widget class="QPushButton" name="exportSTLButton">
     <property name="enabled">
      <bool>true</bool>
     </property>
     <property name="text">
      <string>Export as STL</string>
     </property>
    </widget>
   </item>
   
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation">
      <enum>Qt::Vertical</enum>
     </property>
     <property name="sizeHint" stdset="0">
      <size>
       <width>20</width>
       <height>40</height>
      </size>
     </property>
    </spacer>
   </item>
  </layout>
 </widget>
